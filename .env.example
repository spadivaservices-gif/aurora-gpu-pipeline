# Aurora GPU Pipeline - Environment Configuration

# RunPod API
RUNPOD_API_KEY=your_api_key_here

# Pod Configuration (Dedicated GPU - Primary)
RUNPOD_POD_ID=your_pod_id
RUNPOD_POD_ENDPOINT=https://your-pod-id.runpod.io

# ComfyUI Worker (Image Generation)
COMFYUI_WORKER_ENDPOINT=https://comfyui-worker.runpod.io
COMFYUI_GPU_TYPE=RTX4090
COMFYUI_MAX_JOBS=5

# Kling Video Worker (Video Generation)
KLING_WORKER_ENDPOINT=https://kling-worker.runpod.io
KLING_GPU_TYPE=A40
KLING_MAX_JOBS=3

# Lip Sync Worker (Facial Animation)
LIPSYNC_WORKER_ENDPOINT=https://lipsync-worker.runpod.io
LIPSYNC_GPU_TYPE=RTX4080
LIPSYNC_MAX_JOBS=4

# Motion Transfer Worker (Pose Guidance)
MOTION_WORKER_ENDPOINT=https://motion-worker.runpod.io
MOTION_GPU_TYPE=RTX4080
MOTION_MAX_JOBS=4

# Jupyter GPU Worker (Interactive Development)
JUPYTER_WORKER_ENDPOINT=https://jupyter-worker.runpod.io
JUPYTER_TOKEN=your_secure_token
JUPYTER_PORT=8888

# Serverless Configuration (Auto-Scaling Fallback)
RUNPOD_SERVERLESS_ENABLED=true
RUNPOD_SERVERLESS_TIMEOUT=900

# Redis (Job Queue & Cache)
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging
LOG_LEVEL=INFO

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aurora
DB_USER=aurora_user
DB_PASSWORD=your_db_password
